# 复制为 .env.local 后填写真实值即可生效。三组都可选：不填也能跑 Demo（走本地数据与模板回退）。

# Kimi / Moonshot API（推荐/学习导览/打标签的真实 AI 调用；优先使用）
MOONSHOT_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k-vision-preview

# Claude API（可选备用）
ANTHROPIC_API_KEY=

# Supabase（替代本地种子作为数据源）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
